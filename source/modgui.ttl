@prefix modgui: <http://moddevices.com/ns/modgui#> .
@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .

<https://github.com/OilCanSteve/ocs-channel2port>
    modgui:gui [
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/icon-oilcan-channel2port.html> ;
        modgui:stylesheet <modgui/stylesheet-oilcan-channel2port.css> ;
        modgui:javascript <modgui/channel2port.js> ;
        modgui:screenshot <modgui/screenshot-oilcan-channel2port.png> ;
        modgui:thumbnail <modgui/thumbnail-oilcan-channel2port.png> ;
        modgui:brand "Oil Can" ;
        modgui:label "Channel2Port" ;
        modgui:model "boxy" ;
        modgui:panel "4-knobs" ;
        modgui:color "pink" ;
        modgui:knob "copper" ;
        modgui:port [
            lv2:index 0 ;
            lv2:symbol "ChannelA" ;
            lv2:name "ChannelA" ;
        ], [
            lv2:index 1 ;
            lv2:symbol "ChannelB" ;
            lv2:name "ChannelB" ;
        ], [
            lv2:index 2 ;
            lv2:symbol "ChannelC" ;
            lv2:name "ChannelC" ;
        ], [
            lv2:index 3 ;
            lv2:symbol "ChannelD" ;
            lv2:name "ChannelD" ;
        ] ;
    ] .
